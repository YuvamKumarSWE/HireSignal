# ── Backend ────────────────────────────────────────────────────────────────────

PORT=3000

# Origin allowed to connect (your public domain in prod, e.g. https://hiresignal.com)
ALLOWED_ORIGIN=http://localhost

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Firebase Admin — Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire downloaded JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ── Frontend build args (baked into the image at build time) ──────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
